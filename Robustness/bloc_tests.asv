function [N_test, dt_test, T_test, Q_test, R_test, P0_test] = bloc_test(input_number);

switch input_number
    case 1 % Test 1 : cas nominal (N=10)
        N_test  = 10;
        dt_test = 0.1;
        T_test  = 200;
        Q_test  = diag([0.01, 0.1, 0.5]);
        R_test  = diag([1.0, 0.1]);
        P0_test = eye(3);

    case 2  % Test 2 : N=1 (GPS actif a chaque pas)
        N_test  = 1;
        dt_test = 0.1;
        T_test  = 200;
        Q_test  = diag([0.01, 0.1, 0.5]);
        R_test  = diag([1.0, 0.1]);
        P0_test = eye(3);

    case 3 % Test 3 : N=5
        N_test  = 5;
        dt_test = 0.1;
        T_test  = 200;
        Q_test  = diag([0.01, 0.1, 0.5]);
        R_test  = diag([1.0, 0.1]);
        P0_test = eye(3);

    case 4 % Test 4 : N=20
        N_test  = 20;
        dt_test = 0.1;
        T_test  = 200;
        Q_test  = diag([0.01, 0.1, 0.5]);
        R_test  = diag([1.0, 0.1]);
        P0_test = eye(3);

    case 5 % Test 5 : Q x10 (bruit de process eleve)
        N_test  = 10;
        dt_test = 0.1;
        T_test  = 200;
        Q_test  = diag([0.01, 0.1, 0.5]) * 10;
        R_test  = diag([1.0, 0.1]);
        P0_test = eye(3);

%% Test 6 : Q x0.1 (bruit de process faible)
    case 6
        N_test  = 10;
        dt_test = 0.1;
        T_test  = 200;
        Q_test  = diag([0.01, 0.1, 0.5]) * 0.1;
        R_test  = diag([1.0, 0.1]);
        P0_test = eye(3);

%% Test 7 : R x10 (capteurs peu fiables)
    case 7
        N_test  = 10;
        dt_test = 0.1;
        T_test  = 200;
        Q_test  = diag([0.01, 0.1, 0.5]);
        R_test  = diag([1.0, 0.1]) * 10;
        P0_test = eye(3);

%% Test 8 : R x0.1 (capteurs tres fiables)
    case 8
        N_test  = 10;
        dt_test = 0.1;
        T_test  = 200;
        Q_test  = diag([0.01, 0.1, 0.5]);
        R_test  = diag([1.0, 0.1]) * 0.1;
        P0_test = eye(3);

%% Test 9 : P0 x10 (forte incertitude initiale)
    case 9
        N_test  = 10;
        dt_test = 0.1;
        T_test  = 200;
        Q_test  = diag([0.01, 0.1, 0.5]);
        R_test  = diag([1.0, 0.1]);
        P0_test = eye(3) * 10;

%% Test 10 : P0 x0.1 (faible incertitude initiale)
    case 10
        N_test  = 10;
        dt_test = 0.1;
        T_test  = 200;
        Q_test  = diag([0.01, 0.1, 0.5]);
        R_test  = diag([1.0, 0.1]);
        P0_test = eye(3) * 0.1;

end